{
    "version": 2,
    "framework": null,
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.9.0"
        }
    },
    "buildCommand": "npm run build && mkdir -p /tmp/views",
    "installCommand": "npm install",
    "routes": [
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "APP_NAME": "Frontend Mentor | Time Tracking Dashboard",
        "APP_URL": "https://time-tracking-dashboard-bice-nu.vercel.app",
        "ASSET_URL": "https://time-tracking-dashboard-bice-nu.vercel.app",
        "CACHE_DRIVER": "array",
        "LOG_CHANNEL": "stderr",
        "SESSION_DRIVER": "cookie",
        "VIEW_COMPILED_PATH": "/tmp/views"
    }
}
